# Copy this file to .env.local — Vite reads VITE_* variables at build time.
# .env.local is gitignored — never commit real values.
#
# On Vercel/Netlify/any platform: set VITE_API_URL in the platform dashboard
# instead of a file — it gets baked into the build at deploy time.

# URL of your backend API — no trailing slash
# Local dev:   http://localhost:8000
# Production:  https://your-backend.up.railway.app
VITE_API_URL=http://localhost:8000
