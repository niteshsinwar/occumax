# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://occumax:occumax@localhost:5432/occumax
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Hotel identity ─────────────────────────────────────────────────────────────
HOTEL_NAME=Demo Hotel

# ── Calendar window ────────────────────────────────────────────────────────────
# Days ahead the heatmap, gap scan, and admin stats cover.
SCAN_WINDOW_DAYS=30

# How far ahead (days) a receptionist can place a booking. Must be <= SCAN_WINDOW_DAYS.
BOOKING_WINDOW_DAYS=20

# ── Gap detection ──────────────────────────────────────────────────────────────
# Empty runs longer than this are normal sellable windows, not orphan gaps.
MAX_GAP_NIGHTS=5

# Max SHUFFLE recommendations generated per T1 run.
RECOMMENDATIONS_CAP=25

# ── HHI optimiser safety caps ──────────────────────────────────────────────────
MAX_SWAP_STEPS=500
MAX_OUTER_ITERATIONS=50

# ── Anti-fragmentation gap cost table ─────────────────────────────────────────
# Penalty for leaving an orphaned gap of N nights adjacent to a new booking.
GAP_COST_0N=0
GAP_COST_1N=100
GAP_COST_2N=40
GAP_COST_3N=10
GAP_COST_4N_PLUS=5

# ── Estimated recovery formula ─────────────────────────────────────────────────
# estimated_recovery = base_rate × extended_gap_nights × RECOVERY_FACTOR
# 0.5 = conservative 50% chance the freed nights will sell.
RECOVERY_FACTOR=0.5
