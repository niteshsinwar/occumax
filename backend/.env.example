# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# This app reads ALL config from environment variables.
# Any platform (Railway, Render, Fly.io, AWS, GCP, VPS) works —
# just set these variables in that platform's dashboard instead of a .env file.

# ── Database ───────────────────────────────────────────────────────────────────
# Format:  postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Railway: they inject DATABASE_URL automatically — the app auto-translates it
# Supabase: postgresql+asyncpg://postgres:PASSWORD@db.XYZ.supabase.co:5432/postgres
# Neon:     postgresql+asyncpg://USER:PASSWORD@ep-XYZ.neon.tech/neondb?sslmode=require
# Local:    postgresql+asyncpg://niteshsinwar@localhost:5432/occumax
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ── CORS — frontend origin(s) allowed to call this API ────────────────────────
# Local dev:    http://localhost:5173,http://localhost:5174
# Production:   https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── AI ─────────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Hotel identity ─────────────────────────────────────────────────────────────
HOTEL_NAME=Demo Hotel

# ── Calendar window ────────────────────────────────────────────────────────────
SCAN_WINDOW_DAYS=30
BOOKING_WINDOW_DAYS=20

# ── Gap detection ──────────────────────────────────────────────────────────────
MAX_GAP_NIGHTS=5
MAX_SWAP_STEPS=500
MAX_OUTER_ITERATIONS=50

# ── Anti-fragmentation gap cost table ─────────────────────────────────────────
GAP_COST_0N=0
GAP_COST_1N=100
GAP_COST_2N=40
GAP_COST_3N=10
GAP_COST_4N_PLUS=5
